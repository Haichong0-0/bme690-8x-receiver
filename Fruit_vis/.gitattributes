# Unity .gitattributes Template
# Source: https://github.com/gitattributes/gitattributes/blob/master/Unity.gitattributes
# License: MIT
#
# Attribute macros (lfs / unity-json / unity-yaml) are defined in the repo-root
# /.gitattributes, NOT here: git only honours [attr] macro definitions in the
# top-level .gitattributes, and this project is now a subdirectory of the
# monorepo (it was its own repo root before the flatten). The pattern -> macro
# mappings below still apply, resolving against those root definitions.

# Unity source files
*.cginc text
*.compute text linguist-language=hlsl
*.cs text diff=csharp
*.hlsl text linguist-language=hlsl
*.raytrace text linguist-language=hlsl
*.shader text

# Unity JSON files
*.asmdef unity-json
*.asmref unity-json
*.index unity-json
*.inputactions unity-json
*.shadergraph unity-json
*.shadersubgraph unity-json

# Unity UI Toolkit files
*.tss text diff=css linguist-language=css
*.uss text diff=css linguist-language=css
*.uxml text linguist-language=xml linguist-detectable

# Unity YAML files
*.anim unity-yaml
*.asset unity-yaml
*.brush unity-yaml
*.controller unity-yaml
*.flare unity-yaml
*.fontsettings unity-yaml
*.giparams unity-yaml
*.guiskin unity-yaml
*.lighting unity-yaml
*.mask unity-yaml
*.mat unity-yaml
*.meta unity-yaml
*.mixer unity-yaml
*.overrideController unity-yaml
*.playable unity-yaml
*.prefab unity-yaml
*.preset unity-yaml
*.renderTexture unity-yaml
*.scenetemplate unity-yaml
*.shadervariants unity-yaml
*.signal unity-yaml
*.spriteatlas unity-yaml
*.spriteatlasv2 unity-yaml
*.terrainlayer unity-yaml
*.unity unity-yaml

# "physic" for 3D but "physics" for 2D
*.physicMaterial unity-yaml
*.physicsMaterial2D unity-yaml

# Exclude from GitHub stats and diffs: third-party plugins, packages lock file
Assets/Plugins/** linguist-generated
Packages/packages-lock.json linguist-generated

