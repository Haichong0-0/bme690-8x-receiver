# ---------------------------------------------------------------------------
# ML artifacts are NOT committed — they are either the raw research data (kept
# out of the public repo), or large/regenerable outputs. Everything below can
# be rebuilt from data/raw/ + the code. See the repo-root DATA_AND_RESULTS.md
# for where the data lives and the exact commands to regenerate the dataset,
# models, and figures.
# ---------------------------------------------------------------------------

# Raw capture CSVs — the actual collected sensor data (irreplaceable). Kept out
# of the public repo and shared privately in the data & results bundle; every
# artifact below is rebuilt from these.
data/raw/

# Processed dataset + diagnostic/evaluation figures — generated by
# build_dataset.py / evaluate.py, fully regenerable.
data/processed/
data/diagnostics/
data/diagnostics_const320/
data/diagnostics_eval/

# Trained models — generated by train.py, regenerable (the RandomForest
# regressor alone is ~155 MB, over GitHub's 100 MB per-file limit).
models/

# NOT ignored: experiments.csv / EXPERIMENTS.md — also generated by train.py,
# but they accumulate the training-run history across runs rather than being
# disposable rebuild output, so they persist and ARE committed.

# Held-out test-capture figures (regenerable via testing/test_capture.py)
testing/output/

__pycache__/
*.pyc
experiments.pending.jsonl
